#!/bin/bash

set -euo pipefail

VOLUME="${1}"

sudo cat > smb.conf <<EOF
[global]
   workgroup = WORKGROUP
   server string = XP Backup Server
   netbios name = MACSTUDIO

   # --- all state kept project-local (survives brew upgrade) ---
   private dir = $PWD/samba/private
   state directory = $PWD/samba
   cache directory = $PWD/samba
   lock directory = $PWD/samba
   pid directory = $PWD/samba
   ncalrpc dir = $PWD/samba/ncalrpc
   log file = $PWD/samba/log.%m

   server min protocol = NT1
   server max protocol = NT1
   ntlm auth = yes
   lanman auth = yes
   client lanman auth = yes

   server multi channel support = no

   security = user
   passdb backend = tdbsam

   veto files = /._*/.DS_Store/.Spotlight-V100/.Trashes/
   delete veto files = yes

[actbackup]
   path = ${VOLUME}
   browseable = yes
   read only = no
   writable = yes
   guest ok = no
   valid users = $USER
   force user = $USER
   root preexec = /bin/test -e "${VOLUME}/.actbackup_volume"
   root preexec close = yes
EOF

sudo mkdir -p $PWD/samba
sudo mkdir -p $PWD/samba/private
sudo chmod 700 $PWD/samba/private

sudo /opt/homebrew/bin/smbpasswd -c $PWD/smb.conf -a $USER

sudo cat > com.act.smbd.plist <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
 "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.act.smbd</string>

    <key>ProgramArguments</key>
    <array>
        <string>/opt/homebrew/sbin/samba-dot-org-smbd</string>
        <string>--foreground</string>
        <string>--no-process-group</string>
        <string>--configfile=$PWD/smb.conf</string>
    </array>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>$PWD/samba/launchd.out.log</string>

    <key>StandardErrorPath</key>
    <string>$PWD/samba/launchd.err.log</string>
</dict>
</plist>
EOF

sudo cp com.act.smbd.plist /Library/LaunchDaemons/com.act.smbd.plist
sudo chown root:wheel /Library/LaunchDaemons/com.act.smbd.plist
sudo chmod 644 /Library/LaunchDaemons/com.act.smbd.plist
